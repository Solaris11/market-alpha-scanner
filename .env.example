# PostgreSQL settings for the isolated market-alpha Docker stack.
POSTGRES_DB=market_alpha
POSTGRES_USER=market_alpha
POSTGRES_PASSWORD=change_me_before_production

# Inside Docker, the app reaches PostgreSQL through the private market-alpha network.
DATABASE_URL=postgresql+psycopg://market_alpha:change_me_before_production@market-alpha-postgres:5432/market_alpha

# The Next.js frontend uses node-postgres, so it needs the standard PostgreSQL URL format.
FRONTEND_DATABASE_URL=postgresql://market_alpha:change_me_before_production@market-alpha-postgres:5432/market_alpha
APP_URL=https://app.marketalpha.co
PUBLIC_APP_URL=https://app.marketalpha.co
APP_BASE_URL=https://app.marketalpha.co
MARKET_ALPHA_ADMIN_EMAILS=
# Used only outside NODE_ENV=production for local entitlement testing.
MARKET_ALPHA_DEV_PREMIUM_EMAILS=
MARKET_ALPHA_PREMIUM_EMAILS=
MARKET_ALPHA_MOCK_PREMIUM=false
MARKET_ALPHA_SESSION_SECRET=change_me_to_a_long_random_secret
MARKET_ALPHA_MAX_SCAN_AGE_MINUTES=240
EMAIL_FROM=

# Runtime paths inside the app container.
SCANNER_OUTPUT_DIR=/app/scanner_output
# Postgres is the production source of truth. Keep CSV fallback disabled unless
# explicitly performing a rollback/debug operation.
SCANNER_CSV_FALLBACK=false
APP_LOG_DIR=/app/logs

# Optional Telegram/email alert delivery.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_PASSWORD=

# Stripe billing. Never commit real keys.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Streamlit host port for the separate market-alpha stack.
STREAMLIT_HOST_PORT=18501
